# Public site root URL (no trailing slash).
# Used by: Vite client (canonical / Open Graph), and scripts/generate-sitemap.mjs (sitemap + robots).
# Copy to `.env` and set your real domain, e.g. https://your-site.netlify.app
VITE_SITE_URL=

# Google Analytics 4 — create a GA4 web data stream and copy the Measurement ID (`G-...`).
# Set the same variable in Netlify: Site settings → Environment variables → VITE_GA_MEASUREMENT_ID
# VITE_GA_MEASUREMENT_ID=
