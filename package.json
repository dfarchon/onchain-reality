    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "netlify-cli": "24.6.1",
    "postcss": "8.4.47",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.15",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "8.0.0"
